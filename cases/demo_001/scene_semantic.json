          },
          "style": {
            "color": "YELLOW",
            "position_hint": "ORIGIN"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        },
        {
          "id": "formula_R1",
          "type": "Formula",
          "params": {
            "latex": "R_1 = \\frac{mv_0}{qB_1} = 2d"
          },
          "style": {
            "color": "ORANGE",
            "position_hint": "UP"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        }
      ],
      "narrative_storyboard": {
        "bridge_from_prev": "粒子带着速度v0进入L2-L3区域。",
        "intro": "在磁场B1中，洛伦兹力提供向心力。粒子做匀速圆周运动。根据题目给定的B1大小，我们可以计算出其运动半径。",
        "key_formulae": [
          {
            "latex": "qv_0B_1 = m\\frac{v_0^2}{R_1}",
            "color": "ORANGE",
            "position_hint": "UP",
            "duration_s": 4.0
          },
          {
            "latex": "R_1 = 2d",
            "color": "ORANGE",
            "position_hint": "UP",
            "duration_s": 4.0
          }
        ],
        "animation_steps": [
          {
            "id": "step_1",
            "description": "FadeIn 磁场B1。在L2-L3区域显示蓝色'x'阵列，表示磁场方向。",
