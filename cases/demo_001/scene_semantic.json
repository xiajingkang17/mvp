{
  "version": "0.1",
  "pedagogy_plan": null,
  "scenes": [
    {
      "id": "S1",
      "intent": "展示粒子在电场中加速的过程，推导初速度 v0。",
      "goal": "利用动能定理 qEd = 1/2mv0^2 求解 v0。",
      "modules": [],
      "roles": {},
      "new_symbols": [],
      "is_check_scene": false,
      "notes": "elements: L1/L2边界, 电场线, 粒子, P点, 文本, 公式;\ncolors: 电场线(RED), 粒子(YELLOW), 边界(WHITE);\ngeometry_elements: 4条平行竖线(L1-L4), 水平向右箭头表示电场, 粒子球体;\ngeometry_construction: 先绘制L1-L4四条等距竖线, 在L1-L2间填充红色箭头表示电场E, 在L1上标记P点;\ngeometry_relations: L1与L2间距为d, 电场方向水平向右;\ntransitions: 粒子从P点出现, 沿水平向右加速运动至L2;\ncamera_movement: none;\nlayout: 场景中心为粒子运动区域, 公式显示在上方;\nduration: 12s",
      "objects": [
        {
          "id": "field_system",
          "type": "CompositeObject",
          "params": {
            "semantic_intent": "构建L1-L4边界及L1-L2间的匀强电场",
            "geometry_prompt": "绘制4条垂直于x轴的平行直线，间距为d。在L1和L2之间绘制均匀分布的水平向右箭头，表示匀强电场E。",
            "must_have_parts": [
              "Wall",
              "Arrow"
            ],
            "forbidden_parts": [
              "InclinedPlane"
            ]
          },
          "style": {
            "color": "WHITE",
            "position_hint": "ORIGIN"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        },
        {
          "id": "particle",
          "type": "CompositeObject",
          "params": {
            "semantic_intent": "表示带正电的粒子",
            "geometry_prompt": "绘制一个黄色小球，标记为+q",
