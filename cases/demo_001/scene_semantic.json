        "intro": "若粒子恰好回到P点，其轨迹必须闭合。在B2区域，粒子向上偏转并最终垂直穿过L2回到P。通过几何关系可求出R2，进而求出B2。",
        "key_formulae": [
          {
            "latex": "R_2 = \\frac{2d}{\\sin 60^\\circ}",
            "color": "GREEN",
            "position_hint": "UP",
            "duration_s": 5.0
          },
          {
            "latex": "B_2 = \\sqrt{\\frac{3mE}{2qd}}",
            "color": "GREEN",
            "position_hint": "UP",
            "duration_s": 5.0
          }
        ],
        "animation_steps": [
          {
            "id": "step_1",
            "description": "FadeIn 磁场B2。在L3-L4区域显示紫色'.'阵列。",
            "targets": [
              "magnetic_field_B2"
            ],
            "color_hint": null,
            "position_hint": null,
            "duration_s": 3.0
          },
          {
            "id": "step_2",
            "description": "绘制第二段轨迹。粒子从L3进入B2，画出一段圆弧，最终垂直向上穿过L2回到P点。",
            "targets": [
              "trajectory_B2",
              "particle"
            ],
            "color_hint": null,
            "position_hint": null,
            "duration_s": 6.0
          },
          {
            "id": "step_3",
            "description": "高亮几何约束。高亮显示轨迹的弦长（等于2d）和偏转角（60度），展示R2的计算依据。",
            "targets": [
              "trajectory_B2"
            ],
            "color_hint": null,
            "position_hint": null,
            "duration_s": 5.0
          },
          {
            "id": "step_4",
            "description": "Write 最终结果。显示B2的推导过程和最终表达式。",
            "targets": [
              "formula_B2"
            ],
            "color_hint": null,
            "position_hint": null,
            "duration_s": 4.0
          }
        ],
        "bridge_to_next": "现在我们改变B2的大小，寻找粒子能以最短时间到达Q点的条件。"
      }
