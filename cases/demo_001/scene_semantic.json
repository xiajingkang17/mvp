            "color": "BLUE",
            "position_hint": "ORIGIN"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        },
        {
          "id": "trajectory_B1",
          "type": "CompositeObject",
          "params": {
            "semantic_intent": "粒子在B1中的运动轨迹",
            "geometry_prompt": "绘制一段半圆弧，从L2上的入射点出发，向下偏转，最终切向进入L3。标注半径R1=2d。",
