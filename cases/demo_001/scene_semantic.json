            "color_hint": null,
            "position_hint": null,
            "duration_s": 6.0
          },
          {
            "id": "step_3",
            "description": "标注几何关系。高亮显示轨迹半径，并标注R1=2d，说明粒子恰好经过半个圆周。",
            "targets": [
              "trajectory_B1"
            ],
            "color_hint": null,
            "position_hint": null,
            "duration_s": 4.0
          },
          {
            "id": "step_4",
            "description": "Write 半径公式。显示R1的计算公式，验证B1的取值。",
            "targets": [
              "formula_R1"
            ],
            "color_hint": null,
            "position_hint": null,
            "duration_s": 3.0
          }
        ],
        "bridge_to_next": "粒子穿过L3后，进入L3-L4之间的磁场B2，开始第二次偏转。"
      }
    },
    {
      "id": "S3",
      "intent": "分析粒子在磁场B2中的运动，利用回到P点的几何约束求解B2。",
      "goal": "推导B2 = sqrt(3mE/2qd)。",
      "modules": [],
      "roles": {},
      "new_symbols": [],
      "is_check_scene": false,
      "notes": "elements: 磁场B2区域符号(.), 第二段轨迹, 闭合回路, 几何角度标注;\ncolors: 磁场(PURPLE), 轨迹(YELLOW);\ngeometry_elements: L3-L4区域内的点号阵列, 60度圆弧, 弦长2d;\ngeometry_construction: 在L3-L4区域绘制紫色'.'表示磁场向外。粒子从L3进入，偏转60度后垂直向上穿过L2回到P点;\ngeometry_relations: 第二段轨迹弦长为2d，偏转角为60度，半径R2 = 2d/sin(60°);\ntransitions: 轨迹从L3延续到L2，形成闭合;\ncamera_movement: none;\nlayout: 完整展示从P出发回到P的闭合路径;\nduration: 18s",
      "objects": [
        {
          "id": "magnetic_field_B2",
          "type": "CompositeObject",
          "params": {
            "semantic_intent": "表示L3-L4间垂直向外的匀强磁场B2",
            "geometry_prompt": "在L3和L4之间的区域绘制均匀分布的'.'符号，表示磁场方向垂直纸面向外。",
            "must_have_parts": [
              "FieldCross"
            ]
          },
          "style": {
            "color": "PURPLE",
            "position_hint": "RIGHT"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        },
        {
          "id": "trajectory_B2",
          "type": "CompositeObject",
          "params": {
            "semantic_intent": "粒子在B2中的运动轨迹",
            "geometry_prompt": "绘制一段圆弧，从L3上的出射点出发，向上偏转，最终垂直向上穿过L2回到P点。标注偏转角60度和半径R2。",
            "must_have_parts": [
              "ArcTrack",
              "Arrow"
            ]
          },
          "style": {
            "color": "YELLOW",
            "position_hint": "RIGHT"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        },
        {
          "id": "formula_B2",
          "type": "Formula",
          "params": {
            "latex": "R_2 = \\frac{2d}{\\sin 60^\\circ}, \\quad B_2 = \\frac{mv_0}{qR_2} = \\sqrt{\\frac{3mE}{2qd}}"
          },
          "style": {
            "color": "GREEN",
            "position_hint": "UP"
          },
          "priority": 2,
          "anchor": null,
          "z_index": null
        }
      ],
      "narrative_storyboard": {
