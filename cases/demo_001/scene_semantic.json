          "id": "formula_v0",
          "type": "Formula",
          "params": {
            "latex": "qEd = \\frac{1}{2}mv_0^2 \\implies v_0 = \\sqrt{\\frac{2qEd}{m}}"
          },
          "style": {
            "color": "GREEN",
            "position_hint": "UP"
